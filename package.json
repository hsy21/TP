{
  "name": "travelplan",
  "version": "1.0.0",
  "description": "TravelPlan Node.js Backend",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "share": "npx localtunnel --port 8000 --subdomain travelplan",
    "share:auto": "node tunnel.js",
    "share:serveo": "ssh -R travelplan:80:127.0.0.1:8000 -o StrictHostKeyChecking=no -o ServerAliveInterval=60 serveo.net",
    "share:serveo:auto": "node tunnel_serveo.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "sqlite3": "^5.1.6"
  }
}
