# security 모듈 환경변수 예시 — 프로젝트 루트에 .env 로 복사해 사용
# (운영에서는 반드시 강한 랜덤 시크릿을 넣을 것)

NODE_ENV=development

# JWT 시크릿 (최소 16자, 운영에서는 openssl rand -hex 32 권장)
JWT_ACCESS_SECRET=change-me-access-secret-min-16
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16
JWT_ISSUER=travelplan
JWT_AUDIENCE=travelplan-web

# 토큰 만료 / Grace Period (s, m, h, d)
ACCESS_TTL=15m
REFRESH_TTL=7d
GRACE_TTL=30s

# 비밀번호 해싱 강도
BCRYPT_ROUNDS=12

# 계정 보안 정책
MAX_FAILED_ATTEMPTS=5
LOCK_DURATION=15m
MIN_PASSWORD_LENGTH=8

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=tp:

# CORS 허용 출처 (콤마 구분)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
